/* 产品详情页样式 */
.detail-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 图片轮播区 */
.product-swiper {
  width: 100%;
  height: 600rpx;
}

.swiper-img {
  width: 100%;
  height: 100%;
}

/* 产品信息区 */
.product-info-section {
  background-color: #ffffff;
  padding: 32rpx;
}

.product-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  line-height: 1.4;
}

.product-category {
  margin-top: 16rpx;
}

.category-tag {
  display: inline-block;
  font-size: 24rpx;
  color: #666666;
  background-color: #f0f0f0;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

/* 产品描述区 */
.product-desc-section {
  background-color: #ffffff;
  padding: 32rpx;
  margin-top: 16rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 16rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
  display: block;
  white-space: pre-wrap;
}

/* 底部下单栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background-color: #ffffff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 5%;
  box-sizing: border-box;
}

.order-btn {
  width: 90%;
  height: 88rpx;
  background-color: #07c160;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.order-btn text {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
}

.order-btn.disabled {
  background-color: #cccccc;
}

/* 加载状态 */
.loading-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
}

.loading-page text {
  font-size: 28rpx;
  color: #999999;
}
