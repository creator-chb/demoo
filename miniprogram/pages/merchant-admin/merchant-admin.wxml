<view class="page">
  <!-- 顶部商家信息区域 -->
  <view class="header">
    <view class="header-content">
      <text class="header-title">商家管理后台</text>
      <text class="merchant-name">{{merchantName}}</text>
    </view>
  </view>

  <!-- 功能入口列表 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goToCategories">
      <view class="menu-left">
        <text class="menu-icon">📂</text>
        <view class="menu-info">
          <text class="menu-title">分类管理</text>
          <text class="menu-desc">管理商品分类</text>
        </view>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goToProducts">
      <view class="menu-left">
        <text class="menu-icon">📦</text>
        <view class="menu-info">
          <text class="menu-title">产品管理</text>
          <text class="menu-desc">管理商品信息、上下架</text>
        </view>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goToOrders">
      <view class="menu-left">
        <text class="menu-icon">📋</text>
        <view class="menu-info">
          <text class="menu-title">订单管理</text>
          <text class="menu-desc">查看和处理订单</text>
        </view>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goToQrcode">
      <view class="menu-left">
        <text class="menu-icon">📱</text>
        <view class="menu-info">
          <text class="menu-title">桌号管理</text>
          <text class="menu-desc">生成和管理桌号小程序码</text>
        </view>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录按钮 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="handleLogout">退出登录</button>
  </view>
</view>
