/* 商家管理后台样式 */
.page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 顶部区域 */
.header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 100rpx 40rpx 60rpx;
}

.header-content {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.merchant-name {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 菜单列表 */
.menu-list {
  margin: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f5f5f5;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.menu-info {
  display: flex;
  flex-direction: column;
}

.menu-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
}

.menu-arrow {
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
}

/* 退出登录 */
.logout-section {
  padding: 60rpx 30rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #e64340;
  font-size: 32rpx;
  border: 2rpx solid #e64340;
  border-radius: 44rpx;
}

.logout-btn::after {
  border: none;
}

.logout-btn:active {
  background: #fff5f5;
}
