/* 桌号管理页面样式 */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 顶部区域 */
.header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 100rpx 30rpx 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 24rpx;
}

/* 批量生成区域 */
.batch-section {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.input-row {
  display: flex;
  align-items: flex-end;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.input-group {
  flex: 1;
}

.input-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: none;
}

.separator {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  padding-bottom: 24rpx;
}

.btn-primary {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #fff;
  color: #1890ff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 40rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  opacity: 0.9;
}

.btn-small {
  width: 140rpx;
  flex-shrink: 0;
}

/* 单个生成区域 */
.single-section {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 30rpx;
}

.single-section .section-title {
  margin-bottom: 20rpx;
}

.single-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.single-input {
  flex: 1;
}

/* 列表区域 */
.list-section {
  padding: 30rpx;
}

.list-header {
  margin-bottom: 24rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 网格布局 */
.qrcode-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.qrcode-item {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.table-id {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.qrcode-image {
  width: 240rpx;
  height: 240rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.qrcode-tip {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 120rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #ccc;
}
