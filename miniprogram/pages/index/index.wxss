/**index.wxss - 首页四宫格样式**/
page {
  height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
}

.home-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0 32rpx;
  box-sizing: border-box;
}

/* 顶部安全区 */
.safe-area {
  width: 100%;
  flex-shrink: 0;
}

/* 顶部标题区 */
.header {
  padding: 60rpx 0 40rpx;
  text-align: center;
}

.shop-name {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.shop-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
}

/* 四宫格容器 */
.grid-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  flex: 1;
  padding: 20rpx 0;
}

/* 四宫格单元格 */
.grid-item {
  width: 48%;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 24rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.grid-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
}

/* 图标样式 */
.grid-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
  line-height: 1;
}

/* 标题样式 */
.grid-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

/* 描述样式 */
.grid-desc {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

/* 我要点单 - 绿色主题 */
.grid-order {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
  border: 2rpx solid #a5d6a7;
}

.grid-order .grid-title {
  color: #2e7d32;
}

.grid-order .grid-desc {
  color: #4caf50;
}

.grid-order:active {
  background: linear-gradient(135deg, #c8e6c9 0%, #a5d6a7 100%);
}

/* 我是商家 - 蓝色主题 */
.grid-merchant {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  border: 2rpx solid #90caf9;
}

.grid-merchant .grid-title {
  color: #1565c0;
}

.grid-merchant .grid-desc {
  color: #2196f3;
}

.grid-merchant:active {
  background: linear-gradient(135deg, #bbdefb 0%, #90caf9 100%);
}

/* 二维码展示 */
.grid-qrcode {
  background: #fff;
  border: 2rpx solid #e0e0e0;
}

.grid-qrcode:active {
  transform: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.qrcode-img {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 16rpx;
  border-radius: 8rpx;
}

/* 敬请期待 - 灰色半透明 */
.grid-coming-soon {
  background: #f5f5f5;
  border: 2rpx solid #e0e0e0;
  opacity: 0.6;
}

.grid-coming-soon .grid-icon {
  filter: grayscale(0.5);
}

.grid-coming-soon .grid-title {
  color: #9e9e9e;
}

.grid-coming-soon .grid-desc {
  color: #bdbdbd;
}

.grid-coming-soon:active {
  transform: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

/* 底部桌号显示 */
.footer {
  padding: 32rpx 0 64rpx;
  text-align: center;
}

.footer-text {
  display: inline-block;
  font-size: 28rpx;
  color: #666;
  background: rgba(255, 255, 255, 0.8);
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}
