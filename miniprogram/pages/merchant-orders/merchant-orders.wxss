/* 订单管理页样式 */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* WebSocket连接状态 */
.ws-status {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
  background-color: #f0f0f0;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.ws-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.ws-dot.connected {
  background-color: #07c160;
}

.ws-dot.disconnected {
  background-color: #e64340;
}

.ws-text {
  font-size: 22rpx;
  color: #999;
}

/* 顶部标签栏 */
.header {
  background: #fff;
  padding-top: 128rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tabs-scroll {
  white-space: nowrap;
}

.tabs {
  display: flex;
  padding: 0 20rpx;
}

.tab-item {
  position: relative;
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  color: #666;
  flex-shrink: 0;
}

.tab-item.active {
  color: #1890ff;
  font-weight: 500;
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #1890ff;
  border-radius: 3rpx;
}

/* 订单列表 */
.order-list {
  padding: 20rpx 30rpx;
}

.order-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-no {
  font-size: 26rpx;
  color: #999;
}

.status-tag {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.status-pending {
  background: #fff7e6;
  color: #fa8c16;
}

.status-processing {
  background: #e6f7ff;
  color: #1890ff;
}

.status-completed {
  background: #f6ffed;
  color: #52c41a;
}

.status-cancelled {
  background: #f5f5f5;
  color: #999;
}

/* 桌号信息 */
.table-info {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 24rpx;
}

.table-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-right: 16rpx;
}

.table-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

/* 产品信息 */
.product-info {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}

.product-detail {
  margin-left: 24rpx;
  flex: 1;
}

.product-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.order-time {
  font-size: 26rpx;
  color: #999;
}

/* 操作按钮 */
.order-actions {
  display: flex;
  gap: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 36rpx;
}

.accept-btn {
  background: #1890ff;
  color: #fff;
}

.complete-btn {
  background: #52c41a;
  color: #fff;
}

.reset-btn {
  background: #f5f5f5;
  color: #666;
}

.accept-btn:active {
  background: #096dd9;
}

.complete-btn:active {
  background: #389e0d;
}

.reset-btn:active {
  background: #e8e8e8;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #ccc;
}
