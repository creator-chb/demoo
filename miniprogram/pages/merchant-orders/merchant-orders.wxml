<view class="page">
  <!-- WebSocket连接状态指示器 -->
  <view class="ws-status">
    <view class="ws-dot {{wsConnected ? 'connected' : 'disconnected'}}"></view>
    <text class="ws-text">{{wsConnected ? '实时连接中' : '连接断开'}}</text>
  </view>

  <!-- 顶部标签栏 -->
  <view class="header">
    <scroll-view class="tabs-scroll" scroll-x="true">
      <view class="tabs">
        <view 
          wx:for="{{tabs}}" 
          wx:key="key"
          class="tab-item {{currentTab === item.key ? 'active' : ''}}" 
          data-tab="{{item.key}}"
          bindtap="switchTab"
        >
          <text>{{item.name}}</text>
          <view class="tab-line" wx:if="{{currentTab === item.key}}"></view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list" wx:if="{{orders.length > 0}}">
    <view class="order-card" wx:for="{{orders}}" wx:key="id">
      <!-- 订单头部 -->
      <view class="order-header">
        <view class="order-no">订单号: {{item.order_no || item.id}}</view>
        <view class="status-tag status-{{item.status}}">
          <block wx:if="{{item.status === 'pending'}}">待处理</block>
          <block wx:elif="{{item.status === 'processing'}}">进行中</block>
          <block wx:elif="{{item.status === 'completed'}}">已完成</block>
          <block wx:elif="{{item.status === 'cancelled'}}">已取消</block>
          <block wx:else>{{item.status}}</block>
        </view>
      </view>

      <!-- 桌号醒目显示 -->
      <view class="table-info">
        <text class="table-label">桌号</text>
        <text class="table-number">{{item.table_id || '未知'}}</text>
      </view>

      <!-- 产品信息 -->
      <view class="product-info">
        <image 
          class="product-image" 
          src="{{item.product_image || '/images/default-product.png'}}"
          mode="aspectFill"
        />
        <view class="product-detail">
          <text class="product-name">{{item.product_name}}</text>
          <text class="order-time">{{item.formattedTime}}</text>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="order-actions" wx:if="{{item.status === 'pending' || item.status === 'processing'}}">
        <view 
          class="action-btn accept-btn" 
          wx:if="{{item.status === 'pending'}}"
          data-id="{{item.id}}"
          bindtap="handleAccept"
        >接单</view>
        <view 
          class="action-btn complete-btn" 
          wx:if="{{item.status === 'pending' || item.status === 'processing'}}"
          data-id="{{item.id}}"
          bindtap="handleComplete"
        >完成</view>
        <view 
          class="action-btn reset-btn" 
          wx:if="{{item.status === 'pending' || item.status === 'processing'}}"
          data-id="{{item.id}}"
          bindtap="handleReset"
        >强制重置</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <text class="empty-icon">📋</text>
    <text class="empty-text">暂无订单</text>
    <text class="empty-tip">下拉刷新试试</text>
  </view>
</view>
