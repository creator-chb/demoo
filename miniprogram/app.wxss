/**app.wxss**/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
}

/* 全局通用样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333;
}

.btn-primary {
  background-color: #07c160;
  color: #fff;
  border-radius: 8rpx;
  text-align: center;
  padding: 20rpx 0;
  font-size: 32rpx;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-danger {
  background-color: #e64340;
  color: #fff;
  border-radius: 8rpx;
  text-align: center;
  padding: 20rpx 0;
  font-size: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  padding: 20rpx 30rpx;
  color: #333;
}
